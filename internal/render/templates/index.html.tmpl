{{define "content"}}
<div class="mb-6">
  <h1 class="m-0 mb-1 text-2xl font-semibold">Issue forms</h1>
  <p class="text-gh-muted m-0">Pick a template below to preview it.</p>
</div>
<ul class="list-none m-0 p-0 bg-white border border-gh-border rounded-md divide-y divide-gh-border">
  {{range .Forms}}
    <li class="flex items-center justify-between p-4 gap-4">
      <div>
        <h3 class="m-0 mb-0.5 text-base font-semibold">
          <a href="/forms/{{.Slug}}" class="text-gh-accent hover:underline">{{.Name}}</a>
        </h3>
        <p class="text-gh-muted m-0">{{.Description}}</p>
        <code class="text-gh-muted bg-black/5 px-1.5 py-0.5 rounded font-mono text-[85%]">.github/ISSUE_TEMPLATE/{{.Filename}}</code>
      </div>
      <a href="/forms/{{.Slug}}"
         class="inline-block px-4 py-1.5 text-sm font-medium leading-5 rounded-md border border-black/15 bg-gh-btn hover:bg-gh-btnHover text-white whitespace-nowrap hover:no-underline">
        Get started
      </a>
    </li>
  {{end}}
</ul>
{{end}}
